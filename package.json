{
  "name": "self-introduction",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=24 <27",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev:web": "pnpm --filter @self-introduction/web dev",
