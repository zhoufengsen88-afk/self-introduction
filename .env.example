APP_ENV=local
API_HOST=127.0.0.1
API_PORT=8000
WEB_PORT=3000
DATABASE_URL=postgresql+psycopg://self_intro:self_intro@127.0.0.1:5432/self_intro
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
RAG_BACKEND=memory
EMBEDDING_PROVIDER=hashing

# Answer generation mode:
# - deterministic: no paid LLM call; useful for local smoke tests and eval baselines.
# - llm: send retrieved chunks to an OpenAI-compatible chat completions API.
ANSWER_GENERATOR=deterministic
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=30
LLM_PROMPT_COST_PER_1K=0
LLM_COMPLETION_COST_PER_1K=0

# Optional: send detailed Agent/RAG traces to LiteLLMOps.
# When enabled, LiteLLMOps can store user questions, final answers, prompts,
# retrieval metadata, span inputs/outputs, token usage, and costs.
# 1. Install the local SDK into this project's Python environment:
#    uv pip install -e /Users/zfs/Documents/lite-llmops/sdk/python
# 2. Set APP_ID/API_KEY from the LiteLLMOps application details.
LITE_LLMOPS_ENABLED=false
LITE_LLMOPS_BASE_URL=http://127.0.0.1:8001
# LITE_LLMOPS_APP_ID=1
# LITE_LLMOPS_API_KEY=llmo_xxx
LITE_LLMOPS_MODEL_NAME=self-introduction-agentic-rag
LITE_LLMOPS_TIMEOUT_SECONDS=2

# Optional: improves Hugging Face download rate limits for real embedding providers.
HF_TOKEN=
